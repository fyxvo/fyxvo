{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @fyxvo/config build && pnpm --filter @fyxvo/database build && pnpm --filter @fyxvo/worker build",
    "watchPatterns": [
      "/apps/worker/**",
      "/packages/config/**",
      "/packages/database/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @fyxvo/worker start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 1,
    "sleepApplication": false
  }
}
