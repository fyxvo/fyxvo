# Future mainnet planning only. Do not load this file until runtime support moves beyond devnet-only validation.
FYXVO_ENV=production
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=4000
DATABASE_URL=postgresql://postgres:postgres@db-host:5432/fyxvo
REDIS_URL=redis://redis-host:6379
WEB_ORIGIN=https://www.fyxvo.com
CORS_ALLOWED_ORIGINS=https://www.fyxvo.com,https://status.fyxvo.com
SOLANA_CLUSTER=mainnet-beta
FYXVO_PROGRAM_ID=REPLACE_WITH_MAINNET_PROGRAM_ID
FYXVO_ADMIN_AUTHORITY=REPLACE_WITH_MAINNET_ADMIN_AUTHORITY
FYXVO_AUTHORITY_MODE=multisig
FYXVO_PROTOCOL_AUTHORITY=REPLACE_WITH_MAINNET_PROTOCOL_AUTHORITY
FYXVO_PAUSE_AUTHORITY=REPLACE_WITH_MAINNET_PAUSE_AUTHORITY
FYXVO_UPGRADE_AUTHORITY_HINT=REPLACE_WITH_MAINNET_UPGRADE_AUTHORITY
FYXVO_PROTOCOL_FEE_BPS=500
FYXVO_ENABLE_USDC=false
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com/
REQUEST_TIMEOUT_MS=10000
API_JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
API_RATE_LIMIT_MAX=120
API_RATE_LIMIT_WINDOW_MS=60000
USDC_MINT_ADDRESS=REPLACE_WITH_MAINNET_USDC_MINT
