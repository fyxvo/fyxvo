{
  "$schema": "https://turbo.build/schema.json",
  "daemon": false,
  "remoteCache": {
    "enabled": false
  },
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "cache": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": [],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": [],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build", "^test"],
      "outputs": [],
      "cache": true
    }
  }
}
